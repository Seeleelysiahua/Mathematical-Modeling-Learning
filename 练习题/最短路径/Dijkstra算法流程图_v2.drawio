        </mxCell>

        <mxCell id="e_cond_select" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#333333;strokeWidth=2" edge="1" parent="1" source="cond1" target="select_box">
