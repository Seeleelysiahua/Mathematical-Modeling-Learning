  <diagram name="图3-Dijkstra执行流程图">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- 图注 -->
        <mxCell id="caption3" value="图3 Dijkstra单源最短路径算法执行流程图" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="450" y="20" width="450" height="30" as="geometry" />
        </mxCell>

        <!-- 开始节点 -->
        <mxCell id="start" value="开始" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#00FF00;strokeColor=#008000;fontStyle=1;fontSize=14" vertex="1" parent="1">
          <mxGeometry x="250" y="80" width="80" height="40" as="geometry" />
        </mxCell>

        <!-- 初始化框 -->
        <mxCell id="init_box" value="【初始化】&#xa;S = {c₁}&#xa;T = {c₂,c₃,c₄,c₅,c₆}&#xa;dist[c₁] = 0&#xa;dist[其他] = ∞&#xa;prev[其他] = NULL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F3FF;strokeColor=#4A90D9;fontSize=11;arcSize=20" vertex="1" parent="1">
          <mxGeometry x="200" y="150" width="180" height="100" as="geometry" />
        </mxCell>

        <!-- 判断框 T是否为空? -->
        <mxCell id="cond1" value="T是否为空?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#FF9900;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="230" y="280" width="120" height="80" as="geometry" />
        </mxCell>

        <!-- 是：指向结束 -->
        <mxCell id="yes_label" value="是" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="360" y="290" width="30" height="20" as="geometry" />
        </mxCell>

        <!-- 选择最小节点 -->
        <mxCell id="select_box" value="从T中选择dist最小的节点u" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F3FF;strokeColor=#4A90D9;fontSize=11;arcSize=20" vertex="1" parent="1">
          <mxGeometry x="200" y="390" width="180" height="50" as="geometry" />
        </mxCell>

        <!-- 更新集合S -->
        <mxCell id="update_s" value="将u从T移至S&#xa;S = S ∪ {u}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6FFE6;strokeColor=#00AA00;fontSize=11;arcSize=20" vertex="1" parent="1">
          <mxGeometry x="200" y="465" width="180" height="50" as="geometry" />
        </mxCell>

        <!-- 松弛更新 -->
        <mxCell id="relax_box" value="对u的每个邻居v∈T:&#xa;若 dist[v] > dist[u] + C[u][v]&#xa;    则 dist[v] = dist[u] + C[u][v]&#xa;    并 prev[v] = u" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E6;strokeColor=#FF6600;fontSize=10;arcSize=20" vertex="1" parent="1">
          <mxGeometry x="180" y="540" width="220" height="90" as="geometry" />
        </mxCell>

        <!-- 结束节点 -->
        <mxCell id="end_box" value="输出dist[]和prev[]&#xa;（算法结束）" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#FF6B6B;strokeColor=#CC0000;fontStyle=1;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="400" y="290" width="100" height="50" as="geometry" />
        </mxCell>

        <!-- 连接线 -->
        <mxCell id="e_start_init" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#333333;strokeWidth=2" edge="1" parent="1" source="start" target="init_box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_init_cond" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#333333;strokeWidth=2" edge="1" parent="1" source="init_box" target="cond1">
          <mxGeometry relative="1" as="geometry" />
