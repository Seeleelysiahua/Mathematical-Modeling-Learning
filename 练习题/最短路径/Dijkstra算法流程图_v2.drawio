  <diagram name="图2-Dijkstra迭代过程可视化">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- 图注 -->
        <mxCell id="caption2" value="图2 Dijkstra算法迭代过程可视化" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="500" y="20" width="400" height="30" as="geometry" />
        </mxCell>

        <!-- 第1轮 -->
        <mxCell id="iter1_box" value="第1轮：选择 c₆ (dist=10)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE4E1;strokeColor=#FF6347;fontSize=14;fontStyle=1;arcSize=20" vertex="1" parent="1">
          <mxGeometry x="40" y="70" width="380" height="200" as="geometry" />
        </mxCell>

        <mxCell id="iter1_content" value="【操作】&#xa;从 T={c₂,c₃,c₄,c₅} 中选择 dist 最小的节点&#xa;min(dist) = min(50,∞,40,25,10) = 10 → c₆&#xa;&#xa;【更新邻居】&#xa;• dist[c₂]: 50 → min(50, 10+25) = 35&#xa;• dist[c₄]: 40 → min(40, 10+25) = 35  ← 新增补全&#xa;• dist[c₅]: 25 → min(25, 10+55) = 25 (不变)&#xa;&#xa;【结果】S={c₁,c₆}, T={c₂,c₃,c₄,c₅}" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="50" y="95" width="370" height="170" as="geometry" />
        </mxCell>

        <!-- 第2轮 -->
        <mxCell id="iter2_box" value="第2轮：选择 c₅ (dist=25)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFACD;strokeColor=#FFD700;fontSize=14;fontStyle=1;arcSize=20" vertex="1" parent="1">
          <mxGeometry x="460" y="70" width="380" height="200" as="geometry" />
        </mxCell>

        <mxCell id="iter2_content" value="【操作】&#xa;从 T={c₂,c₃,c₄} 中选择 dist 最小的节点&#xa;min(dist) = min(35,∞,35,25) = 25 → c₅&#xa;&#xa;【更新邻居】&#xa;• dist[c₃]: ∞ → min(∞, 25+20) = 45&#xa;• dist[c₄]: 35 → min(35, 25+10) = 35 (不变)&#xa;• dist[c₂]: 35 → min(35, 25+∞) = 35 (不变)&#xa;&#xa;【结果】S={c₁,c₅,c₆}, T={c₂,c₃,c₄}" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="470" y="95" width="370" height="170" as="geometry" />
        </mxCell>

        <!-- 第3轮 -->
        <mxCell id="iter3_box" value="第3轮：选择 c₂ (dist=35)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0FFFF;strokeColor=#00CED1;fontSize=14;fontStyle=1;arcSize=20" vertex="1" parent="1">
          <mxGeometry x="880" y="70" width="460" height="200" as="geometry" />
        </mxCell>

        <mxCell id="iter3_content" value="【操作】&#xa;从 T={c₃,c₄} 中选择 dist 最小的节点&#xa;min(dist) = min(35,45,35) = 35&#xa;&#xa;【临时距离均为35，本次选取c₂加入永久集】&#xa;【c₄仍保留在临时集合T，下轮继续】&#xa;&#xa;【更新邻居】&#xa;• dist[c₃]: 45 → min(45, 35+15) = 45 (不变)&#xa;• dist[c₄]: 35 → min(35, 35+20) = 35 (不变)&#xa;&#xa;【结果】S={c₁,c₂,c₅,c₆}, T={c₃,c₄}" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="890" y="95" width="440" height="170" as="geometry" />
        </mxCell>

        <!-- 第4轮 -->
        <mxCell id="iter4_box" value="第4轮：选择 c₄ (dist=35)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6E6FA;strokeColor=#9370DB;fontSize=14;fontStyle=1;arcSize=20" vertex="1" parent="1">
          <mxGeometry x="460" y="310" width="380" height="200" as="geometry" />
        </mxCell>

        <mxCell id="iter4_content" value="【操作】&#xa;从 T={c₃} 中选择 dist 最小的节点&#xa;min(dist) = min(45,35) = 35 → c₄&#xa;&#xa;【更新邻居】&#xa;• dist[c₃]: 45 → min(45, 35+10) = 45 (不变)&#xa;&#xa;【结果】S={c₁,c₂,c₄,c₅,c₆}, T={c₃}" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="470" y="335" width="370" height="170" as="geometry" />
        </mxCell>

        <!-- 第5轮 -->
        <mxCell id="iter5_box" value="第5轮：选择 c₃ (dist=45) - 算法结束" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#98FB98;strokeColor=#228B22;fontSize=14;fontStyle=1;arcSize=20" vertex="1" parent="1">
          <mxGeometry x="40" y="310" width="380" height="200" as="geometry" />
        </mxCell>

        <mxCell id="iter5_content" value="【操作】&#xa;从 T={c₃} 中选择 dist 最小的节点&#xa;min(dist) = 45 → c₃&#xa;&#xa;【更新邻居】&#xa;无剩余 T 中邻居节点&#xa;&#xa;【结果】S={c₁,c₂,c₃,c₄,c₅,c₆}, T={}&#xa;算法结束！所有节点已确定最短距离" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="50" y="335" width="370" height="170" as="geometry" />
        </mxCell>

        <!-- 箭头连接 -->
        <mxCell id="arr1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#FF6347;strokeWidth=2;endArrow=classic" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="420" y="170" as="sourcePoint" />
            <mxPoint x="460" y="170" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <mxCell id="arr2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#FFD700;strokeWidth=2;endArrow=classic" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="840" y="170" as="sourcePoint" />
            <mxPoint x="880" y="170" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <mxCell id="arr3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#00CED1;strokeWidth=2;endArrow=classic" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1100" y="270" as="sourcePoint" />
            <mxPoint x="650" y="310" as="targetPoint" />
          </mxGeometry>
        </mxCell>

