  <diagram name="迭代过程详细图" id="iteration_detail">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- 标题 -->
        <mxCell id="iter_title" value="Dijkstra算法 - 迭代过程可视化" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="500" y="20" width="400" height="40" as="geometry" />
        </mxCell>

        <!-- 第1轮 -->
        <mxCell id="iter1_box" value="第1轮：选择c₆ (dist=10)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE4E1;strokeColor=#FF6347;fontSize=14;fontStyle=1;arcSize=20" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="400" height="180" as="geometry" />
        </mxCell>

        <mxCell id="iter1_content" value="【操作】&#xa;从T={c₂,c₃,c₄,c₅}中选择dist最小的节点&#xa;min(dist) = min(∞,∞,∞,25,10) = 10 → c₆&#xa;&#xa;【更新邻居】&#xa;• dist[c₂]: ∞ → min(∞, 10+25) = 35&#xa;• dist[c₄]: ∞ → min(∞, 10+25) = 35&#xa;• dist[c₅]: 25 → min(25, 10+55) = 25 (不变)&#xa;&#xa;【结果】S={c₁,c₆}, T={c₂,c₃,c₄,c₅}" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="50" y="110" width="380" height="140" as="geometry" />
        </mxCell>

        <!-- 第2轮 -->
        <mxCell id="iter2_box" value="第2轮：选择c₅ (dist=25)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFACD;strokeColor=#FFD700;fontSize=14;fontStyle=1;arcSize=20" vertex="1" parent="1">
          <mxGeometry x="480" y="80" width="400" height="180" as="geometry" />
        </mxCell>

        <mxCell id="iter2_content" value="【操作】&#xa;从T={c₂,c₃,c₄}中选择dist最小的节点&#xa;min(dist) = min(35,∞,35,25) = 25 → c₅&#xa;&#xa;【更新邻居】&#xa;• dist[c₃]: ∞ → min(∞, 25+20) = 45&#xa;• dist[c₄]: 35 → min(35, 25+100) = 35 (不变)&#xa;• dist[c₂]: 35 → min(35, 25+∞) = 35 (不变)&#xa;&#xa;【结果】S={c₁,c₅,c₆}, T={c₂,c₃,c₄}" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="490" y="110" width="380" height="140" as="geometry" />
        </mxCell>

        <!-- 第3轮 -->
        <mxCell id="iter3_box" value="第3轮：选择c₂ (dist=35)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0FFFF;strokeColor=#00CED1;fontSize=14;fontStyle=1;arcSize=20" vertex="1" parent="1">
          <mxGeometry x="920" y="80" width="400" height="180" as="geometry" />
        </mxCell>

        <mxCell id="iter3_content" value="【操作】&#xa;从T={c₃,c₄}中选择dist最小的节点&#xa;min(dist) = min(35,45,35) = 35 → c₂&#xa;(c₄也是35，选c₂或c₄均可)&#xa;&#xa;【更新邻居】&#xa;• dist[c₃]: 45 → min(45, 35+15) = 45 (不变)&#xa;• dist[c₄]: 35 → min(35, 35+20) = 35 (不变)&#xa;&#xa;【结果】S={c₁,c₂,c₅,c₆}, T={c₃,c₄}" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="930" y="110" width="380" height="140" as="geometry" />
        </mxCell>

        <!-- 第4轮 -->
        <mxCell id="iter4_box" value="第4轮：选择c₄ (dist=35)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6E6FA;strokeColor=#9370DB;fontSize=14;fontStyle=1;arcSize=20" vertex="1" parent="1">
          <mxGeometry x="480" y="300" width="400" height="180" as="geometry" />
        </mxCell>

        <mxCell id="iter4_content" value="【操作】&#xa;从T={c₃}中选择dist最小的节点&#xa;min(dist) = min(45,35) = 35 → c₄&#xa;&#xa;【更新邻居】&#xa;• dist[c₃]: 45 → min(45, 35+10) = 45 (不变)&#xa;&#xa;【结果】S={c₁,c₂,c₄,c₅,c₆}, T={c₃}" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="490" y="330" width="380" height="140" as="geometry" />
        </mxCell>

        <!-- 第5轮 -->
        <mxCell id="iter5_box" value="第5轮：选择c₃ (dist=45) - 算法结束" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#98FB98;strokeColor=#228B22;fontSize=14;fontStyle=1;arcSize=20" vertex="1" parent="1">
          <mxGeometry x="40" y="300" width="400" height="180" as="geometry" />
        </mxCell>

        <mxCell id="iter5_content" value="【操作】&#xa;从T={c₃}中选择dist最小的节点&#xa;min(dist) = 45 → c₃&#xa;&#xa;【更新邻居】&#xa;无剩余T中邻居节点&#xa;&#xa;【结果】S={c₁,c₂,c₃,c₄,c₅,c₆}, T={}&#xa;算法结束！所有节点已确定最短距离" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="50" y="330" width="380" height="140" as="geometry" />
        </mxCell>

        <!-- 最终结果 -->
        <mxCell id="final_box" value="【最终结果】" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0F8FF;strokeColor=#4169E1;fontSize=16;fontStyle=1;arcSize=25" vertex="1" parent="1">
          <mxGeometry x="480" y="520" width="400" height="320" as="geometry" />
        </mxCell>

        <mxCell id="final_dist" value="【最短距离】&#xa;dist[1]=0, dist[2]=35, dist[3]=45&#xa;dist[4]=35, dist[5]=25, dist[6]=10&#xa;&#xa;【前驱节点】&#xa;prev[1]=-, prev[2]=c₆, prev[3]=c₄&#xa;prev[4]=c₆, prev[5]=c₁, prev[6]=c₁&#xa;&#xa;【回溯路径】&#xa;• c₂: c₁←c₆←c₂ → c₁→c₆→c₂ (35元)&#xa;• c₃: c₁←c₆←c₄←c₃ → c₁→c₆→c₄→c₃ (45元)&#xa;• c₄: c₁←c₆←c₄ → c₁→c₆→c₄ (35元)&#xa;• c₅: c₁←c₅ → c₁→c₅ (25元)&#xa;• c₆: c₁←c₆ → c₁→c₆ (10元)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="490" y="550" width="380" height="280" as="geometry" />
        </mxCell>

        <!-- 箭头连接 -->
        <mxCell id="arr1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#FF6347;strokeWidth=2" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="240" y="260" as="sourcePoint" />
            <mxPoint x="680" y="280" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <mxCell id="arr2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#FFD700;strokeWidth=2" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="880" y="260" as="sourcePoint" />
            <mxPoint x="1100" y="260" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <mxCell id="arr3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#00CED1;strokeWidth=2" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1120" y="260" as="sourcePoint" />
            <mxPoint x="680" y="300" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <mxCell id="arr4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#9370DB;strokeWidth=2" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="680" y="480" as="sourcePoint" />
            <mxPoint x="240" y="480" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <mxCell id="arr5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#228B22;strokeWidth=2" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="440" y="480" as="sourcePoint" />
            <mxPoint x="680" y="520" as="targetPoint" />
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
