  <diagram name="Dijkstra算法流程图" id="flowchart">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- 标题 -->
        <mxCell id="title1" value="Dijkstra单源最短路径算法 - 执行流程图" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="600" height="40" as="geometry" />
        </mxCell>

        <!-- 开始节点 -->
        <mxCell id="start" value="开始" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#00FF00;strokeColor=#008000;fontStyle=1;fontSize=14" vertex="1" parent="1">
          <mxGeometry x="650" y="80" width="80" height="40" as="geometry" />
        </mxCell>

        <!-- 初始化步骤 -->
        <mxCell id="init1" value="初始化&#xa;dist[1]=0, dist[2..6]=∞&#xa;S={c₁}, T={c₂,c₃,c₄,c₅,c₆}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F3FF;strokeColor=#4A90D9;fontSize=12;arcSize=20" vertex="1" parent="1">
          <mxGeometry x="575" y="150" width="150" height="60" as="geometry" />
        </mxCell>

        <!-- 循环条件 -->
        <mxCell id="cond1" value="T是否为空?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#FF9900;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="600" y="240" width="100" height="80" as="geometry" />
        </mxCell>

        <!-- 选择最小节点 -->
        <mxCell id="select1" value="从T中选择dist最小的节点u" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F3FF;strokeColor=#4A90D9;fontSize=12;arcSize=20" vertex="1" parent="1">
          <mxGeometry x="575" y="360" width="150" height="50" as="geometry" />
        </mxCell>

        <!-- 更新集合 -->
        <mxCell id="update1" value="将u从T移至S&#xa;S = S ∪ {u}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6FFE6;strokeColor=#00AA00;fontSize=12;arcSize=20" vertex="1" parent="1">
          <mxGeometry x="575" y="440" width="150" height="50" as="geometry" />
        </mxCell>

        <!-- 更新距离 -->
        <mxCell id="relax1" value="对u的每个邻居v∈T:&#xa;若dist[u]+C[u][v]&lt;dist[v]:&#xa;  更新dist[v]&#xa;  更新prev[v]=u" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E6;strokeColor=#FF6600;fontSize=11;arcSize=20" vertex="1" parent="1">
          <mxGeometry x="550" y="520" width="200" height="80" as="geometry" />
        </mxCell>

        <!-- 结束 -->
        <mxCell id="end" value="结束&#xa;输出dist[]和prev[]" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#FF6B6B;strokeColor=#CC0000;fontStyle=1;fontSize=14" vertex="1" parent="1">
          <mxGeometry x="630" y="640" width="100" height="50" as="geometry" />
        </mxCell>

        <!-- 连接线 -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#333333;strokeWidth=2" edge="1" parent="1" source="start" target="init1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#333333;strokeWidth=2" edge="1" parent="1" source="init1" target="cond1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#333333;strokeWidth=2" edge="1" parent="1" source="cond1" target="select1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="650" y="240" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#333333;strokeWidth=2" edge="1" parent="1" source="select1" target="update1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#333333;strokeWidth=2" edge="1" parent="1" source="update1" target="relax1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#333333;strokeWidth=2" edge="1" parent="1" source="relax1" target="cond1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#333333;strokeWidth=2" edge="1" parent="1" source="cond1" target="end">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="700" y="280" as="targetPoint" />
