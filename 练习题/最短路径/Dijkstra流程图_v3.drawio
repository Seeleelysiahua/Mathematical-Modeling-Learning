  <diagram name="图2-Dijkstra迭代过程可视化">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="20" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- 图注 -->
        <mxCell id="cap2" value="图2 Dijkstra算法迭代过程可视化" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="550" y="20" width="300" height="30" as="geometry" />
        </mxCell>

        <!-- ========== 五轮迭代框（整齐排列）========== -->
        <!-- 第1轮 -->
        <mxCell id="r1_box" value="第1轮：选择 c₆ (dist=10)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE4E1;strokeColor=#FF6347;fontSize=13;fontStyle=1;arcSize=20" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="380" height="180" as="geometry" />
        </mxCell>

        <mxCell id="r1_txt" value="【操作】&#xa;从 T={c₂,c₃,c₄,c₅} 中选择 dist 最小的节点&#xa;min(dist) = min(50,∞,40,25,10) = 10 → c₆&#xa;&#xa;【更新邻居】&#xa;• dist[c₂]: 50 → min(50, 10+25) = 35&#xa;• dist[c₄]: 40 → min(40, 10+25) = 35  ← 新增&#xa;• dist[c₅]: 25 → min(25, 10+55) = 25 (不变)&#xa;&#xa;【结果】S={c₁,c₆}, T={c₂,c₃,c₄,c₅}" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="50" y="100" width="365" height="155" as="geometry" />
        </mxCell>

        <!-- 第2轮 -->
        <mxCell id="r2_box" value="第2轮：选择 c₅ (dist=25)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFACD;strokeColor=#FFD700;fontSize=13;fontStyle=1;arcSize=20" vertex="1" parent="1">
          <mxGeometry x="460" y="80" width="380" height="180" as="geometry" />
        </mxCell>

        <mxCell id="r2_txt" value="【操作】&#xa;从 T={c₂,c₃,c₄} 中选择 dist 最小的节点&#xa;min(dist) = min(35,∞,35,25) = 25 → c₅&#xa;&#xa;【更新邻居】&#xa;• dist[c₃]: ∞ → min(∞, 25+20) = 45&#xa;• dist[c₄]: 35 → min(35, 25+10) = 35 (不变)&#xa;• dist[c₂]: 35 → min(35, 25+∞) = 35 (不变)&#xa;&#xa;【结果】S={c₁,c₅,c₆}, T={c₂,c₃,c₄}" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="470" y="100" width="365" height="155" as="geometry" />
        </mxCell>

        <!-- 第3轮 -->
        <mxCell id="r3_box" value="第3轮：选择 c₂ (dist=35)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0FFFF;strokeColor=#00CED1;fontSize=13;fontStyle=1;arcSize=20" vertex="1" parent="1">
          <mxGeometry x="880" y="80" width="480" height="180" as="geometry" />
        </mxCell>

        <mxCell id="r3_txt" value="【操作】&#xa;从 T={c₃,c₄} 中选择 dist 最小的节点&#xa;min(dist) = min(35,45,35) = 35&#xa;&#xa;【临时距离均为35，选取c₂加入永久集】&#xa;【c₄仍保留在临时集合T，下轮继续】&#xa;&#xa;【更新邻居】&#xa;• dist[c₃]: 45 → min(45, 35+15) = 45 (不变)&#xa;• dist[c₄]: 35 → min(35, 35+20) = 35 (不变)&#xa;&#xa;【结果】S={c₁,c₂,c₅,c₆}, T={c₃,c₄}" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="890" y="100" width="465" height="155" as="geometry" />
        </mxCell>

        <!-- 箭头1→2 -->
        <mxCell id="a12" value="" style="endArrow=classic;html=1;strokeColor=#FF6347;strokeWidth=2" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="420" y="170" as="sourcePoint" />
            <mxPoint x="460" y="170" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- 箭头2→3 -->
        <mxCell id="a23" value="" style="endArrow=classic;html=1;strokeColor=#FFD700;strokeWidth=2" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="840" y="170" as="sourcePoint" />
            <mxPoint x="880" y="170" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- 第4轮 -->
        <mxCell id="r4_box" value="第4轮：选择 c₄ (dist=35)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6E6FA;strokeColor=#9370DB;fontSize=13;fontStyle=1;arcSize=20" vertex="1" parent="1">
          <mxGeometry x="460" y="300" width="380" height="180" as="geometry" />
        </mxCell>

        <mxCell id="r4_txt" value="【操作】&#xa;从 T={c₃} 中选择 dist 最小的节点&#xa;min(dist) = min(45,35) = 35 → c₄&#xa;&#xa;【更新邻居】&#xa;• dist[c₃]: 45 → min(45, 35+10) = 45 (不变)&#xa;&#xa;【结果】S={c₁,c₂,c₄,c₅,c₆}, T={c₃}" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="470" y="320" width="365" height="155" as="geometry" />
        </mxCell>

        <!-- 第5轮 -->
        <mxCell id="r5_box" value="第5轮：选择 c₃ (dist=45) - 算法结束" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#98FB98;strokeColor=#228B22;fontSize=13;fontStyle=1;arcSize=20" vertex="1" parent="1">
          <mxGeometry x="40" y="300" width="380" height="180" as="geometry" />
        </mxCell>

        <mxCell id="r5_txt" value="【操作】&#xa;从 T={c₃} 中选择 dist 最小的节点&#xa;min(dist) = 45 → c₃&#xa;&#xa;【更新邻居】&#xa;无剩余 T 中邻居节点&#xa;&#xa;【结果】S={c₁,c₂,c₃,c₄,c₅,c₆}, T={}&#xa;算法结束！所有节点已确定最短距离" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="50" y="320" width="365" height="155" as="geometry" />
        </mxCell>

        <!-- 箭头3→4 -->
        <mxCell id="a34" value="" style="endArrow=classic;html=1;strokeColor=#00CED1;strokeWidth=2" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1100" y="260" as="sourcePoint" />
            <mxPoint x="650" y="300" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- 箭头4→5 -->
        <mxCell id="a45" value="" style="endArrow=classic;html=1;strokeColor=#9370DB;strokeWidth=2" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="650" y="480" as="sourcePoint" />
            <mxPoint x="420" y="480" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- 箭头5→最终结果 -->
        <mxCell id="a5f" value="" style="endArrow=classic;html=1;strokeColor=#228B22;strokeWidth=2" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="420" y="380" as="sourcePoint" />
            <mxPoint x="650" y="510" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- ========== 最终结果框（三栏分区）========== -->
        <mxCell id="f_box" value="【最终结果】" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0F8FF;strokeColor=#4169E1;fontSize=15;fontStyle=1;arcSize=25" vertex="1" parent="1">
          <mxGeometry x="460" y="520" width="900" height="260" as="geometry" />
        </mxCell>

        <!-- 分隔线1 -->
        <mxCell id="sep1" value="" style="endArrow=none;html=1;strokeColor=#CCCCCC;strokeWidth=1" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="760" y="530" as="sourcePoint" />
            <mxPoint x="760" y="770" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- 分隔线2 -->
        <mxCell id="sep2" value="" style="endArrow=none;html=1;strokeColor=#CCCCCC;strokeWidth=1" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
