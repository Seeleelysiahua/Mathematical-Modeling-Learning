          <mxGeometry x="780" y="540" width="260" height="25" as="geometry" />
        </mxCell>

        <mxCell id="f_prev" value="prev[c₁] = -&#xa;prev[c₂] = c₆&#xa;prev[c₃] = c₅&#xa;prev[c₄] = c₆&#xa;prev[c₅] = c₁&#xa;prev[c₆] = c₁" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;fontFamily=Courier New" vertex="1" parent="1">
