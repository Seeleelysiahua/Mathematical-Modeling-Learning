  <diagram name="图3-Dijkstra执行流程图">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="20" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- 图注 -->
        <mxCell id="cap3" value="图3 Dijkstra单源最短路径算法执行流程图" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="500" y="20" width="400" height="30" as="geometry" />
        </mxCell>

        <!-- ========== 左侧流程图（整齐垂直排列）========== -->
        <!-- 开始 -->
        <mxCell id="start" value="开始" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#90EE90;strokeColor=#228B22;fontStyle=1;fontSize=14" vertex="1" parent="1">
          <mxGeometry x="220" y="80" width="80" height="40" as="geometry" />
        </mxCell>

        <!-- 初始化 -->
        <mxCell id="init" value="【初始化】&#xa;S = {c₁}&#xa;T = {c₂,c₃,c₄,c₅,c₆}&#xa;dist[c₁] = 0, 其他 = ∞&#xa;prev[其他] = NULL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F3FF;strokeColor=#4A90D9;fontSize=11;arcSize=20" vertex="1" parent="1">
          <mxGeometry x="160" y="150" width="200" height="90" as="geometry" />
        </mxCell>

        <!-- 判断框 -->
        <mxCell id="cond" value="T是否为空?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#FF9900;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="200" y="280" width="120" height="80" as="geometry" />
        </mxCell>

        <!-- 选择节点 -->
        <mxCell id="select" value="从T中选择dist最小的节点u" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F3FF;strokeColor=#4A90D9;fontSize=11;arcSize=20" vertex="1" parent="1">
          <mxGeometry x="160" y="400" width="200" height="50" as="geometry" />
        </mxCell>

        <!-- 更新集合 -->
        <mxCell id="update_s" value="将u从T移至S&#xa;S = S ∪ {u}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6FFE6;strokeColor=#00AA00;fontSize=11;arcSize=20" vertex="1" parent="1">
          <mxGeometry x="160" y="475" width="200" height="50" as="geometry" />
        </mxCell>

        <!-- 松弛更新 -->
        <mxCell id="relax" value="对u的每个邻居v∈T:&#xa;若 dist[v] > dist[u] + C[u][v]&#xa;  则 dist[v] = dist[u] + C[u][v]&#xa;  并 prev[v] = u" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E6;strokeColor=#FF6600;fontSize=10;arcSize=20" vertex="1" parent="1">
          <mxGeometry x="140" y="555" width="240" height="80" as="geometry" />
        </mxCell>

        <!-- 结束 -->
        <mxCell id="end" value="输出dist[]和prev[]&#xa;(算法结束)" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#FFB6C1;strokeColor=#CC0000;fontStyle=1;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="380" y="290" width="100" height="50" as="geometry" />
        </mxCell>

        <!-- 连接线 -->
        <mxCell id="c_start_init" value="" style="endArrow=classic;html=1;strokeColor=#333333;strokeWidth=2" edge="1" parent="1" source="start" target="init">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="c_init_cond" value="" style="endArrow=classic;html=1;strokeColor=#333333;strokeWidth=2" edge="1" parent="1" source="init" target="cond">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 否：向下到选择节点 -->
        <mxCell id="c_cond_sel" value="否" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="270" y="365" width="30" height="20" as="geometry" />
        </mxCell>

        <mxCell id="c_cond_select" value="" style="endArrow=classic;html=1;strokeColor=#333333;strokeWidth=2" edge="1" parent="1" source="cond" target="select">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="260" y="360" as="targetPoint" />
