        <mxCell id="f_path" value="c₂: c₁→c₆→c₂ (35元)&#xa;c₃: c₁→c₅→c₃ (45元)&#xa;c₄: c₁→c₆→c₄ (35元)&#xa;c₅: c₁→c₅ (25元)&#xa;c₆: c₁→c₆ (10元)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;fontFamily=Courier New" vertex="1" parent="1">
