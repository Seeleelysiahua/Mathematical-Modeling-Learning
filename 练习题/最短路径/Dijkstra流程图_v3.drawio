          <mxGeometry x="470" y="540" width="280" height="25" as="geometry" />
        </mxCell>

        <mxCell id="f_dist" value="dist[c₁] = 0&#xa;dist[c₂] = 35&#xa;dist[c₃] = 45&#xa;dist[c₄] = 35&#xa;dist[c₅] = 25&#xa;dist[c₆] = 10" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="480" y="570" width="260" height="120" as="geometry" />
