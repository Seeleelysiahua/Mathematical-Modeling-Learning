<mxfile host="Electron">
  <diagram id="greedy-flowchart" name="贪心算法流程图">
    <mxGraphModel dx="1157" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="1200" math="0" shadow="0">
