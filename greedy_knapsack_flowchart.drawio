          <mxGeometry height="50" width="450" x="325" y="180" as="geometry" />
        </mxCell>
        <mxCell id="6" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=12;fillColor=#E3F2FD;strokeColor=#1976D2;" value="按性价比从高到低排序&#xa;生成货物顺序列表" vertex="1">
          <mxGeometry height="50" width="450" x="325" y="250" as="geometry" />
        </mxCell>
        <mxCell id="7" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=12;fillColor=#FFF3E0;strokeColor=#FF9800;" value="初始化：&#xa;累计重量 = 0 | 累计利润 = 0 | 选中集合 = ∅" vertex="1">
          <mxGeometry height="50" width="450" x="325" y="320" as="geometry" />
        </mxCell>
