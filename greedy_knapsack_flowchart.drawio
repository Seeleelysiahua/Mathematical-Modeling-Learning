        <mxCell id="9" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=12;fillColor=#E3F2FD;strokeColor=#1976D2;" value="取当前货物 i&#xa;计算：累计重量 + 货物i重量" vertex="1">
          <mxGeometry height="50" width="450" x="325" y="490" as="geometry" />
