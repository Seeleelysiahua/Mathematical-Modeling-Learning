        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="2" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=16;fontStyle=1;fontColor=#333333;" value="0-1背包货物运输问题 · 贪心算法执行流程" vertex="1">
          <mxGeometry height="30" width="450" x="325" as="geometry" />
        </mxCell>
        <mxCell id="3" parent="1" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fontSize=14;fontStyle=1;fillColor=#4CAF50;fontColor=#FFFFFF;strokeColor=#388E3C;" value="开始" vertex="1">
          <mxGeometry height="60" width="150" x="475" y="30" as="geometry" />
        </mxCell>
        <mxCell id="4" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=12;fillColor=#E3F2FD;strokeColor=#1976D2;" value="输入：10件货物的重量、利润&#xa;货车载重上限 = 30t" vertex="1">
          <mxGeometry height="50" width="450" x="325" y="110" as="geometry" />
        </mxCell>
