        <mxCell id="10" parent="1" style="rhombus;whiteSpace=wrap;html=1;fontSize=11;fillColor=#FFF9C4;strokeColor=#F9A825;" value="累计重量 + 货物i重量&#xa;≤ 30t ？" vertex="1">
          <mxGeometry height="90" width="350" x="375" y="560" as="geometry" />
